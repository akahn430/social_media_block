{
  "manifest_version": 3,
  "name": "Social Block",
  "description": "Hide distracting blocks and customize page elements with a minimal side panel.",
  "version": "1.1.0",
  "permissions": ["storage", "tabs", "sidePanel"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Social Block"
  },
  "side_panel": {
    "default_path": "sidepanel/sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content-script.js"],
      "run_at": "document_idle"
    }
  ]
}
