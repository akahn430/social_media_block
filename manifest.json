{
  "manifest_version": 3,
  "name": "Focus Blocks",
  "description": "Hide distracting blocks (feeds, reels, sidebars, etc.) per site with customizable profiles.",
  "version": "1.0.0",
  "permissions": ["storage", "tabs", "sidePanel"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Focus Blocks"
  },
  "side_panel": {
    "default_path": "sidepanel/sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content-script.js"],
      "run_at": "document_idle"
    }
  ]
}
